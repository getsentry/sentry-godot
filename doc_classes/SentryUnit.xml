<?xml version="1.0" encoding="UTF-8" ?>
<class name="SentryUnit" inherits="Object" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/godotengine/godot/master/doc/class.xsd">
	<brief_description>
		Unit constants for metric distributions and gauges.
	</brief_description>
	<description>
		Provides predefined unit constants for use with [method SentryMetrics.gauge] and [method SentryMetrics.distribution]. Each property returns a unit string recognized by Sentry. Custom unit strings are also supported — pass any string directly to the metric methods.
		[codeblock]
		SentrySDK.metrics.gauge("memory_usage", OS.get_static_memory_usage(), SentryUnit.byte)
		SentrySDK.metrics.distribution("level_load_time", load_time, SentryUnit.millisecond)

		# Custom units are also supported:
		SentrySDK.metrics.gauge("items_in_inventory", item_count, "item")
		[/codeblock]
	</description>
	<tutorials>
	</tutorials>
